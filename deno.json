{
  "tasks": {
    "vite:dev": "deno run -A npm:vite",
    "desktop:dev": "APP_ENV=development deno desktop --hmr --allow-net --allow-env --allow-read main.ts",
    "build": "deno run -A npm:vite build && deno desktop --allow-net --allow-env --allow-read --include dist --output ./dist-app/fpct.AppImage main.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "vite": "npm:vite@^8.1.3"
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable", "dom.asynciterable"]
  }
}
