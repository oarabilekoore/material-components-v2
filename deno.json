{
  "name": "material-deno",
  "version": "0.1.0",
  "exports": {
    ".": "./packages/mui/index.ts",
    "./core": "./packages/core/index.ts"
  },
  "tasks": {
    "vite:dev": "deno run -A npm:vite",
    "desktop:dev": "APP_ENV=development deno desktop --hmr --allow-net --allow-env --allow-read main.ts",
    "build": "deno run -A npm:vite build && deno desktop --allow-net --allow-env --allow-read --include dist --output ./dist-app/fpct.AppImage main.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "highlight.js": "npm:highlight.js@^11.11.1",
    "marked": "npm:marked@^18.0.5",
    "marked-highlight": "npm:marked-highlight@^2.2.4",
    "vite": "npm:vite@^8.1.3",
    "@material/material-color-utilities": "npm:@material/material-color-utilities@^0.3.0",
    "@antigravity/core": "./packages/core/index.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable", "dom.asynciterable"]
  }
}
